<script>
// ─── TAB SWITCHING ───
function switchTab(tab, btn) {
  document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('tab-' + tab).classList.add('active');
  btn.classList.add('active');
}

// ─── UTILS ───
function now() {
  const d = new Date();
  return d.toISOString().replace('T', ' ').substring(0, 19);
}

function randomHex(n) {
  return [...Array(n)].map(() => Math.floor(Math.random()*16).toString(16)).join('').toUpperCase();
}

function randomId() {
  return 'rec' + randomHex(7).toLowerCase();
}

// ─── TERMINAL ───
let logCount = 0;

function addLog(text, type = 'default') {
  const body = document.getElementById('terminal-body');
  const empty = document.getElementById('terminal-empty');
  const status = document.getElementById('log-status');

  if (empty) empty.style.display = 'none';
  status.textContent = 'ACTIVE';
  status.style.color = 'var(--emerald)';

  logCount++;
  const line = document.createElement('span');
  line.className = 'log-line';
  line.style.animationDelay = (logCount * 0.05) + 's';

  if (type === 'info') line.classList.add('log-info');
  if (type === 'warn') line.classList.add('log-warn');
  if (type === 'boot') line.classList.add('log-boot');

  line.innerHTML = `<span class="log-ts">[${now()}]</span> ${text}`;
  body.appendChild(line);
  body.scrollTop = body.scrollHeight;
  logCount = 0;
}

function addLogDelayed(text, delay, type) {
  setTimeout(() => addLog(text, type), delay);
}

// ─── ENROLLMENT ───
function openPaymentModal() {
  const name = document.getElementById('student-name').value.trim();
  const email = document.getElementById('student-email').value.trim();
  const track = document.getElementById('student-track').value;

  if (!name || !email || !track) {
    alert('Please fill in all fields before proceeding to checkout.');
    return;
  }

  document.getElementById('modal-name-display').textContent = name;
  document.getElementById('modal-email-display').textContent = email;
  document.getElementById('modal-track-display').textContent = track;
  document.getElementById('payment-modal').classList.add('open');

  addLog(`🔒 CHECKOUT: Gateway session opened for <strong>${name}</strong>`, 'info');
  addLogDelayed(`📋 FORM: Validated fields — Name, Email, Track [${track}]`, 150, 'boot');
}

function closePaymentModal() {
  document.getElementById('payment-modal').classList.remove('open');
  addLog('❌ CHECKOUT: Session dismissed by user — no transaction processed.', 'warn');
}

function simulatePayment() {
  const name = document.getElementById('student-name').value.trim();
  const email = document.getElementById('student-email').value.trim();
  const track = document.getElementById('student-track').value;
  const recId = randomId();
  const txRef = 'TXN-APX-' + randomHex(8);

  document.getElementById('payment-modal').classList.remove('open');

  // Populate success card
  document.getElementById('success-track').textContent = track;
  document.getElementById('success-name').textContent = name;
  document.getElementById('alert-text').innerHTML =
    `Core data successfully pushed to Airtable Master Database. A personalized registration receipt has been sent to <strong>${email}</strong>. To maximize retention and prevent early-stage platform churn, a strict <strong>2-Day Operational Delay</strong> has been locked onto this user record before the automated Slack Workspace Invitation link is released to their inbox.`;

  const card = document.getElementById('success-card');
  card.classList.remove('visible');
  void card.offsetWidth;
  card.classList.add('visible');

  // Reset form
  document.getElementById('student-name').value = '';
  document.getElementById('student-email').value = '';
  document.getElementById('student-track').value = '';

  // Pre-fill credentials tab with enrolled track
  const gradTrack = document.getElementById('grad-track');
  for (let i = 0; i < gradTrack.options.length; i++) {
    if (gradTrack.options[i].value === track) { gradTrack.selectedIndex = i; break; }
  }

  // Logs
  addLog(`⚡ TRIGGER: Payment confirmed for <strong>${name}</strong> on <strong>${track}</strong> Track.`);
  addLogDelayed(`💳 GATEWAY: Paystack ref <span style="color:var(--gold)">${txRef}</span> — ₦150,000 authorized.`, 300);
  addLogDelayed(`⚙️ ACTION: Syncing fields to Airtable Base row ID: <span style="color:var(--gold)">${recId}</span>`, 700);
  addLogDelayed(`✅ AIRTABLE: Write confirmed — Name, Email, Track, Timestamp, TxRef stored.`, 1200, 'info');
  addLogDelayed(`⏳ DELAY: 48-Hour hold applied before Slack link deployment to prevent churn.`, 2500, 'warn');
  addLogDelayed(`🔒 RECORD: User record locked with deployment_gate: PENDING_48H_HOLD`, 3000, 'warn');

  sendEnrollmentEmail(name, email, track, txRef);
}

// ─── CREDENTIALS ───
function generateCertificate() {
  const name = document.getElementById('grad-name').value.trim();
  const track = document.getElementById('grad-track').value;
  if (!name) { alert('Please enter the graduate\'s full name.'); return; }
  if (!track) { alert('Please select a training track.'); return; }

  const certId = 'CF-APX-2026-' + randomHex(5);
  const today = new Date().toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' });

  document.getElementById('cert-name-display').textContent = name;
  document.getElementById('cert-track-display').textContent = track;
  document.getElementById('cert-id').textContent = certId;
  document.getElementById('cert-date').textContent = today;
  document.getElementById('cert-id-confirm').textContent = certId;

  const wrapper = document.getElementById('cert-wrapper');
  wrapper.classList.remove('visible');
  void wrapper.offsetWidth;
  wrapper.classList.add('visible');

  // Logs
  addLog(`🎓 CREDENTIALS: Canvas API overlay executed for <strong>${name}</strong> — Track: <strong>${track}</strong>.`);
  addLogDelayed(`🆔 CERT-ID: Unique identifier assigned — <span style="color:var(--gold)">${certId}</span>`, 400);
  addLogDelayed(`🖨️ RENDER: High-resolution certificate asset generated at 300dpi.`, 800, 'info');
  addLogDelayed(`📦 OUTPUT: Asset routed to automated distribution node queue.`, 1300, 'info');
  addLogDelayed(`✅ DISPATCH: Credential delivery confirmed — record indexed in verification registry.`, 1800);
}

function resetCertificate() {
  document.getElementById('cert-wrapper').classList.remove('visible');
  document.getElementById('grad-name').value = '';
  document.getElementById('grad-track').value = '';
}

function downloadCertificate() {
  const name = document.getElementById('cert-name-display').textContent || 'Graduate';
  const track = document.getElementById('cert-track-display').textContent || 'Professional Development Program';
  const certId = document.getElementById('cert-id').textContent;
  const certDate = document.getElementById('cert-date').textContent;

  const canvas = document.createElement('canvas');
  canvas.width = 1200;
  canvas.height = 800;
  const ctx = canvas.getContext('2d');

  // Background gradient
  const bg = ctx.createLinearGradient(0, 0, 1200, 800);
  bg.addColorStop(0, '#0d1f3c');
  bg.addColorStop(0.6, '#0a1628');
  bg.addColorStop(1, '#0d2040');
  ctx.fillStyle = bg;
  ctx.fillRect(0, 0, 1200, 800);

  // Outer border
  ctx.strokeStyle = 'rgba(245,158,11,0.5)';
  ctx.lineWidth = 4;
  ctx.strokeRect(20, 20, 1160, 760);

  // Inner border
  ctx.strokeStyle = 'rgba(245,158,11,0.2)';
  ctx.lineWidth = 1;
  ctx.strokeRect(36, 36, 1128, 728);

  // Seal circle
  ctx.beginPath();
  ctx.arc(600, 120, 44, 0, Math.PI * 2);
  ctx.strokeStyle = 'rgba(245,158,11,0.5)';
  ctx.lineWidth = 2;
  ctx.stroke();
  ctx.font = '44px serif';
  ctx.textAlign = 'center';
  ctx.fillText('🏅', 600, 135);

  // Org text
  ctx.font = '500 14px monospace';
  ctx.fillStyle = 'rgba(245,158,11,0.75)';
  ctx.letterSpacing = '6px';
  ctx.fillText('APEX TECH ACADEMY · COHORTFLOW CERTIFIED', 600, 195);

  // Title
  ctx.font = '500 18px monospace';
  ctx.fillStyle = 'rgba(203,213,225,0.7)';
  ctx.fillText('CERTIFICATE OF COMPLETION', 600, 240);

  // Divider
  ctx.beginPath();
  const grad = ctx.createLinearGradient(440, 0, 760, 0);
  grad.addColorStop(0, 'transparent');
  grad.addColorStop(0.5, 'rgba(245,158,11,0.6)');
  grad.addColorStop(1, 'transparent');
  ctx.strokeStyle = grad;
  ctx.lineWidth = 1;
  ctx.moveTo(440, 268); ctx.lineTo(760, 268);
  ctx.stroke();

  // Name
  ctx.font = 'italic 64px Georgia, serif';
  ctx.fillStyle = '#fef3c7';
  ctx.shadowColor = 'rgba(245,158,11,0.4)';
  ctx.shadowBlur = 20;
  ctx.fillText(name, 600, 370);
  ctx.shadowBlur = 0;

  // Divider 2
  ctx.beginPath();
  ctx.moveTo(440, 405); ctx.lineTo(760, 405);
  ctx.strokeStyle = grad;
  ctx.lineWidth = 1;
  ctx.stroke();

  // Body text
  ctx.font = '300 16px Georgia, serif';
  ctx.fillStyle = 'rgba(203,213,225,0.7)';
  ctx.fillText('has completed the full curriculum of the', 600, 450);
  ctx.font = 'bold 18px Georgia, serif';
  ctx.fillStyle = '#10b981';
  ctx.fillText(track, 600, 485);
  ctx.font = '300 16px Georgia, serif';
  ctx.fillStyle = 'rgba(203,213,225,0.7)';
  ctx.fillText('and is hereby awarded this verified credential.', 600, 520);

  // Meta
  const metaY = 610;
  ctx.font = '500 12px monospace';
  ctx.fillStyle = 'rgba(148,163,184,0.5)';
  ctx.fillText('CERTIFICATE ID', 380, metaY);
  ctx.fillText('ISSUE DATE', 600, metaY);
  ctx.fillText('ISSUED BY', 820, metaY);

  ctx.font = '500 14px monospace';
  ctx.fillStyle = 'rgba(245,158,11,0.8)';
  ctx.fillText(certId, 380, metaY + 24);
  ctx.fillText(certDate, 600, metaY + 24);
  ctx.fillText('COHORTFLOW ENGINE', 820, metaY + 24);

  // Download
  const link = document.createElement('a');
  link.download = `CohortFlow_Certificate_${name.replace(/\s+/g,'_')}.png`;
  link.href = canvas.toDataURL('image/png');
  link.click();

  addLog(`⬇️ DOWNLOAD: Certificate asset exported for <strong>${name}</strong> — <span style="color:var(--gold)">${certId}</span>`, 'info');
}

// ─── EMAILJS CONFIG — replace these three values with yours ───
const EMAILJS_PUBLIC_KEY  = 'YOUR_PUBLIC_KEY';   // Account > API Keys
const EMAILJS_SERVICE_ID  = 'YOUR_SERVICE_ID';   // Email Services tab
const EMAILJS_TEMPLATE_ID = 'YOUR_TEMPLATE_ID';  // Email Templates tab

// Uses the EmailJS REST API directly — works from file:// and any hosted environment
async function sendEnrollmentEmail(name, email, track, txRef) {
  const date = new Date().toLocaleDateString('en-GB', { day: '2-digit', month: 'long', year: 'numeric' });

  addLogDelayed(`📤 EMAILJS: Dispatching confirmation to <span style="color:var(--gold)">${email}</span>...`, 1700, 'info');

  try {
    const res = await fetch('https://api.emailjs.com/api/v1.0/email/send', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        service_id:  EMAILJS_SERVICE_ID,
        template_id: EMAILJS_TEMPLATE_ID,
        user_id:     EMAILJS_PUBLIC_KEY,
        template_params: { name, email, track, tx_ref: txRef, date }
      })
    });

    if (res.ok) {
      addLogDelayed(`✅ EMAIL: Delivery confirmed — receipt sent to <span style="color:var(--gold)">${email}</span>`, 2000, 'info');
    } else {
      const errText = await res.text();
      addLogDelayed(`⚠️ EMAIL: Dispatch failed — ${errText}`, 2000, 'warn');
    }
  } catch (err) {
    addLogDelayed(`⚠️ EMAIL: Network error — ${err.message}`, 2000, 'warn');
  }
}

// ─── BOOT LOGS ───
window.addEventListener('load', () => {
  addLog(`🚀 BOOT: CohortFlow Infrastructure Engine v2.4.1 initialized.`, 'boot');
  addLogDelayed(`🔌 CONNECT: Sandbox environment linked to Apex Tech Academy.`, 300, 'boot');
  addLogDelayed(`✅ STATUS: All services nominal. Awaiting intake events.`, 600, 'boot');
  addLogDelayed(`━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━`, 900, 'dim');
});
</script>
