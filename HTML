<!DOCTYPE html>
<html lang="en">
<head> 
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CohortFlow Infrastructure Engine</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:ital,wght@0,300;0,400;0,500;1,400&family=Playfair+Display:ital,wght@0,700;1,500;1,700&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&display=swap" rel="stylesheet">
<style>
  :root {
    --navy: #0a0f1e;
    --navy-2: #111827;
    --navy-3: #1a2540;
    --navy-4: #1e2d4a;
    --slate: #2d3d5a;
    --slate-light: #3d5175;
    --emerald: #10b981;
    --emerald-dark: #059669;
    --emerald-glow: rgba(16,185,129,0.15);
    --gold: #f59e0b;
    --gold-light: #fbbf24;
    --white: #f8fafc;
    --white-dim: #e2e8f0;
    --text-muted: #94a3b8;
    --text-body: #cbd5e1;
    --border: rgba(255,255,255,0.08);
    --border-active: rgba(16,185,129,0.4);
    --card: rgba(255,255,255,0.04);
    --card-hover: rgba(255,255,255,0.07);
    --radius: 12px;
    --radius-lg: 16px;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--navy);
    color: var(--white);
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* ─── BACKGROUND ─── */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 50% at 20% -10%, rgba(16,185,129,0.07) 0%, transparent 60%),
      radial-gradient(ellipse 60% 40% at 80% 110%, rgba(30,45,74,0.6) 0%, transparent 60%);
    pointer-events: none;
    z-index: 0;
  }

  /* ─── HEADER ─── */
  header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(10,15,30,0.92);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--border);
    padding: 0 40px;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .header-brand {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .header-logo {
    width: 34px;
    height: 34px;
    background: linear-gradient(135deg, var(--emerald) 0%, #06b6d4 100%);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 14px;
    color: white;
    letter-spacing: -0.5px;
    font-family: 'DM Mono', monospace;
    flex-shrink: 0;
  }

  .header-title {
    font-family: 'DM Mono', monospace;
    font-size: 13px;
    font-weight: 500;
    color: var(--white-dim);
    letter-spacing: 0.03em;
  }

  .header-title span {
    color: var(--emerald);
  }

  .header-badge {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    padding: 4px 10px;
    border-radius: 20px;
    background: var(--emerald-glow);
    border: 1px solid var(--border-active);
    color: var(--emerald);
    letter-spacing: 0.05em;
  }

  .header-badge::before {
    content: '● ';
    animation: pulse-dot 2s infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  /* ─── LAYOUT ─── */
  .app-shell {
    position: relative;
    z-index: 1;
    max-width: 1280px;
    margin: 0 auto;
    padding: 32px 40px 64px;
  }

  /* ─── TABS ─── */
  .tab-nav {
    display: flex;
    gap: 4px;
    margin-bottom: 32px;
    background: rgba(255,255,255,0.03);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 6px;
    width: fit-content;
  }

  .tab-btn {
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    font-weight: 500;
    padding: 9px 20px;
    border-radius: 8px;
    border: none;
    background: transparent;
    color: var(--text-muted);
    cursor: pointer;
    transition: all 0.2s;
    letter-spacing: 0.02em;
    white-space: nowrap;
  }

  .tab-btn:hover { color: var(--white-dim); background: rgba(255,255,255,0.04); }

  .tab-btn.active {
    background: linear-gradient(135deg, var(--emerald-dark) 0%, #0d9488 100%);
    color: white;
    box-shadow: 0 2px 12px rgba(16,185,129,0.3);
  }

  /* ─── SECTION PANEL ─── */
  .tab-panel { display: none; animation: fadeIn 0.3s ease; }
  .tab-panel.active { display: block; }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .section-header {
    margin-bottom: 28px;
  }

  .section-eyebrow {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.12em;
    color: var(--emerald);
    text-transform: uppercase;
    margin-bottom: 8px;
  }

  .section-title {
    font-size: 22px;
    font-weight: 600;
    color: var(--white);
    letter-spacing: -0.02em;
  }

  .section-desc {
    font-size: 14px;
    color: var(--text-muted);
    margin-top: 6px;
    line-height: 1.6;
    max-width: 560px;
  }

  /* ─── CARD ─── */
  .card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 32px;
    backdrop-filter: blur(8px);
  }

  /* ─── FORM ─── */
  .form-grid { display: grid; gap: 20px; }

  .form-group { display: flex; flex-direction: column; gap: 7px; }

  .form-label {
    font-size: 12px;
    font-weight: 500;
    color: var(--text-muted);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-family: 'DM Mono', monospace;
  }

  .form-control {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 8px;
    padding: 12px 16px;
    color: var(--white);
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    transition: all 0.2s;
    outline: none;
    width: 100%;
  }

  .form-control::placeholder { color: rgba(148,163,184,0.5); }

  .form-control:focus {
    border-color: var(--emerald);
    background: rgba(16,185,129,0.05);
    box-shadow: 0 0 0 3px rgba(16,185,129,0.1);
  }

  .form-control option {
    background: var(--navy-2);
    color: var(--white);
  }

  /* ─── BUTTONS ─── */
  .btn-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    background: linear-gradient(135deg, var(--emerald) 0%, #0d9488 100%);
    color: white;
    border: none;
    border-radius: 10px;
    padding: 14px 28px;
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
    letter-spacing: 0.01em;
    width: 100%;
    margin-top: 8px;
    box-shadow: 0 4px 20px rgba(16,185,129,0.25);
  }

  .btn-primary:hover {
    transform: translateY(-1px);
    box-shadow: 0 8px 28px rgba(16,185,129,0.35);
  }

  .btn-primary:active { transform: translateY(0); }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    background: rgba(255,255,255,0.06);
    color: var(--white-dim);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 12px 24px;
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
  }

  .btn-secondary:hover { background: rgba(255,255,255,0.1); border-color: rgba(255,255,255,0.15); }

  /* ─── MODAL ─── */
  .modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(5,10,20,0.85);
    backdrop-filter: blur(6px);
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s;
  }

  .modal-overlay.open { opacity: 1; pointer-events: all; }

  .modal-box {
    background: var(--navy-2);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 20px;
    padding: 36px;
    width: 460px;
    max-width: 95vw;
    transform: scale(0.95) translateY(10px);
    transition: transform 0.25s cubic-bezier(0.34,1.56,0.64,1);
    box-shadow: 0 32px 80px rgba(0,0,0,0.6);
  }

  .modal-overlay.open .modal-box { transform: scale(1) translateY(0); }

  .modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 24px;
  }

  .modal-brand {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .modal-logo-ps {
    width: 36px;
    height: 36px;
    background: linear-gradient(135deg, #00c3f7 0%, #0066ff 100%);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 800;
    font-size: 13px;
    color: white;
    font-family: 'DM Mono', monospace;
  }

  .modal-brand-name {
    font-size: 14px;
    font-weight: 600;
    color: var(--white);
  }

  .modal-brand-sub {
    font-size: 11px;
    color: var(--text-muted);
    font-family: 'DM Mono', monospace;
  }

  .modal-close {
    background: rgba(255,255,255,0.06);
    border: none;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    color: var(--text-muted);
    cursor: pointer;
    font-size: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
  }
  .modal-close:hover { background: rgba(255,255,255,0.12); color: white; }

  .modal-divider { height: 1px; background: var(--border); margin: 20px 0; }

  .modal-amount-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: rgba(16,185,129,0.07);
    border: 1px solid rgba(16,185,129,0.2);
    border-radius: 10px;
    padding: 16px 20px;
    margin-bottom: 20px;
  }

  .modal-amount-label { font-size: 13px; color: var(--text-muted); }

  .modal-amount-value {
    font-family: 'DM Mono', monospace;
    font-size: 24px;
    font-weight: 500;
    color: var(--emerald);
  }

  .modal-fields { display: grid; gap: 14px; margin-bottom: 20px; }

  .modal-field-row {
    display: flex;
    align-items: center;
    gap: 10px;
    background: rgba(255,255,255,0.03);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 12px 16px;
  }

  .modal-field-icon { font-size: 16px; }
  .modal-field-text { font-size: 13px; color: var(--text-body); }

  .btn-pay {
    width: 100%;
    padding: 15px;
    background: linear-gradient(135deg, #00c3f7 0%, #0066ff 100%);
    color: white;
    border: none;
    border-radius: 10px;
    font-family: 'DM Sans', sans-serif;
    font-size: 15px;
    font-weight: 700;
    cursor: pointer;
    letter-spacing: 0.01em;
    transition: all 0.2s;
    box-shadow: 0 4px 20px rgba(0,102,255,0.35);
  }

  .btn-pay:hover { transform: translateY(-1px); box-shadow: 0 8px 28px rgba(0,102,255,0.45); }

  .modal-secure {
    text-align: center;
    margin-top: 14px;
    font-size: 11px;
    color: var(--text-muted);
    font-family: 'DM Mono', monospace;
  }

  /* ─── SUCCESS CARD ─── */
  .success-card {
    display: none;
    background: linear-gradient(135deg, rgba(16,185,129,0.1) 0%, rgba(6,182,212,0.07) 100%);
    border: 1px solid rgba(16,185,129,0.3);
    border-radius: var(--radius-lg);
    padding: 32px;
    animation: successIn 0.5s cubic-bezier(0.34,1.56,0.64,1);
    margin-top: 24px;
  }

  @keyframes successIn {
    from { opacity: 0; transform: scale(0.95) translateY(12px); }
    to { opacity: 1; transform: scale(1) translateY(0); }
  }

  .success-card.visible { display: block; }

  .success-headline {
    font-size: 18px;
    font-weight: 600;
    color: var(--white);
    margin-bottom: 16px;
    line-height: 1.5;
  }

  .success-headline .track-name {
    color: var(--emerald);
    font-style: italic;
  }

  .success-headline .student-name {
    color: var(--gold-light);
  }

  .alert-box {
    background: rgba(0,0,0,0.3);
    border: 1px solid rgba(16,185,129,0.2);
    border-left: 3px solid var(--emerald);
    border-radius: 8px;
    padding: 16px 20px;
    margin-top: 16px;
  }

  .alert-label {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    color: var(--emerald);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 6px;
  }

  .alert-text {
    font-size: 13px;
    color: var(--text-body);
    line-height: 1.65;
  }

  /* ─── CERTIFICATE SECTION ─── */
  .cert-input-row {
    display: flex;
    gap: 12px;
    align-items: flex-end;
    max-width: 560px;
    margin-bottom: 32px;
  }

  .cert-input-row .form-group { flex: 1; margin: 0; }

  .btn-generate {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: linear-gradient(135deg, var(--emerald) 0%, #0d9488 100%);
    color: white;
    border: none;
    border-radius: 10px;
    padding: 13px 22px;
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    white-space: nowrap;
    transition: all 0.2s;
    box-shadow: 0 4px 16px rgba(16,185,129,0.25);
    flex-shrink: 0;
  }

  .btn-generate:hover { transform: translateY(-1px); box-shadow: 0 6px 22px rgba(16,185,129,0.35); }

  /* ─── CERTIFICATE ─── */
  .cert-wrapper {
    display: none;
    animation: fadeIn 0.5s ease;
  }

  .cert-wrapper.visible { display: block; }

  .certificate {
    background: linear-gradient(160deg, #0d1f3c 0%, #0a1628 60%, #0d2040 100%);
    border: 3px solid transparent;
    background-clip: padding-box;
    border-radius: 16px;
    position: relative;
    overflow: hidden;
    padding: 52px 64px;
    text-align: center;
    box-shadow: 0 20px 60px rgba(0,0,0,0.5), 0 0 0 3px rgba(245,158,11,0.3);
    margin-bottom: 24px;
  }

  .certificate::before {
    content: '';
    position: absolute;
    inset: 8px;
    border: 1px solid rgba(245,158,11,0.2);
    border-radius: 10px;
    pointer-events: none;
  }

  .certificate::after {
    content: '';
    position: absolute;
    inset: 12px;
    border: 1px solid rgba(245,158,11,0.1);
    border-radius: 8px;
    pointer-events: none;
  }

  .cert-corner {
    position: absolute;
    width: 40px;
    height: 40px;
    border-color: var(--gold);
    border-style: solid;
    opacity: 0.6;
  }

  .cert-corner-tl { top: 18px; left: 18px; border-width: 2px 0 0 2px; border-radius: 4px 0 0 0; }
  .cert-corner-tr { top: 18px; right: 18px; border-width: 2px 2px 0 0; border-radius: 0 4px 0 0; }
  .cert-corner-bl { bottom: 18px; left: 18px; border-width: 0 0 2px 2px; border-radius: 0 0 0 4px; }
  .cert-corner-br { bottom: 18px; right: 18px; border-width: 0 2px 2px 0; border-radius: 0 0 4px 0; }

  .cert-watermark {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-size: 200px;
    opacity: 0.025;
    pointer-events: none;
    font-family: 'DM Mono', monospace;
    font-weight: 700;
    color: var(--gold);
    white-space: nowrap;
  }

  .cert-seal {
    width: 72px;
    height: 72px;
    margin: 0 auto 20px;
    background: radial-gradient(circle, rgba(245,158,11,0.2) 0%, transparent 70%);
    border: 2px solid rgba(245,158,11,0.4);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 32px;
    position: relative;
    box-shadow: 0 0 20px rgba(245,158,11,0.15), inset 0 0 20px rgba(245,158,11,0.05);
  }

  .cert-seal::before {
    content: '';
    position: absolute;
    inset: 5px;
    border: 1px dashed rgba(245,158,11,0.3);
    border-radius: 50%;
  }

  .cert-org {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.2em;
    color: rgba(245,158,11,0.7);
    text-transform: uppercase;
    margin-bottom: 10px;
  }

  .cert-title-text {
    font-family: 'DM Mono', monospace;
    font-size: 13px;
    letter-spacing: 0.15em;
    color: rgba(203,213,225,0.7);
    text-transform: uppercase;
    margin-bottom: 6px;
  }

  .cert-subtitle {
    font-size: 12px;
    color: rgba(148,163,184,0.6);
    margin-bottom: 24px;
  }

  .cert-name {
    font-family: 'Playfair Display', serif;
    font-size: 46px;
    font-style: italic;
    font-weight: 500;
    color: #fef3c7;
    line-height: 1.2;
    margin-bottom: 12px;
    text-shadow: 0 2px 20px rgba(245,158,11,0.3);
    letter-spacing: 0.02em;
  }

  .cert-divider {
    width: 120px;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(245,158,11,0.5), transparent);
    margin: 16px auto;
  }

  .cert-body-text {
    font-size: 13px;
    color: rgba(203,213,225,0.7);
    line-height: 1.7;
    max-width: 420px;
    margin: 0 auto 20px;
  }

  .cert-track-name {
    font-family: 'Playfair Display', serif;
    font-size: 15px;
    font-weight: 700;
    color: var(--emerald);
    letter-spacing: 0.03em;
  }

  .cert-meta-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 32px;
    margin-top: 20px;
  }

  .cert-meta-item {
    text-align: center;
  }

  .cert-meta-label {
    font-family: 'DM Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.15em;
    color: rgba(148,163,184,0.5);
    text-transform: uppercase;
    margin-bottom: 4px;
  }

  .cert-meta-value {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    color: rgba(245,158,11,0.7);
  }

  .cert-meta-divider {
    width: 1px;
    height: 28px;
    background: rgba(245,158,11,0.2);
  }

  .cert-confirmation {
    background: rgba(16,185,129,0.06);
    border: 1px solid rgba(16,185,129,0.2);
    border-radius: 10px;
    padding: 16px 20px;
    margin-bottom: 16px;
  }

  .cert-confirmation-text {
    font-size: 13px;
    color: var(--text-body);
    line-height: 1.6;
  }

  .cert-confirmation-text strong {
    color: var(--emerald);
    font-family: 'DM Mono', monospace;
    font-size: 12px;
  }

  .cert-actions { display: flex; gap: 12px; }

  /* ─── AUDIT LOG ─── */
  .terminal {
    background: #050a0f;
    border: 1px solid rgba(16,185,129,0.2);
    border-radius: var(--radius-lg);
    overflow: hidden;
    min-height: 480px;
    display: flex;
    flex-direction: column;
  }

  .terminal-bar {
    background: rgba(255,255,255,0.04);
    border-bottom: 1px solid rgba(255,255,255,0.06);
    padding: 12px 18px;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .terminal-dots { display: flex; gap: 6px; }

  .terminal-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }

  .dot-red { background: #ff5f57; }
  .dot-yellow { background: #ffbd2e; }
  .dot-green { background: #28c840; }

  .terminal-title {
    font-family: 'DM Mono', monospace;
    font-size: 12px;
    color: var(--text-muted);
    letter-spacing: 0.05em;
    flex: 1;
    text-align: center;
  }

  .terminal-badge {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    padding: 2px 8px;
    border-radius: 4px;
    background: rgba(16,185,129,0.12);
    color: var(--emerald);
    border: 1px solid rgba(16,185,129,0.2);
  }

  .terminal-body {
    flex: 1;
    padding: 20px;
    overflow-y: auto;
    font-family: 'DM Mono', monospace;
    font-size: 12px;
    line-height: 1.8;
  }

  .log-line {
    display: block;
    color: var(--emerald);
    opacity: 0;
    transform: translateX(-8px);
    animation: logIn 0.3s ease forwards;
    margin-bottom: 2px;
  }

  @keyframes logIn {
    to { opacity: 1; transform: translateX(0); }
  }

  .log-ts { color: rgba(16,185,129,0.5); }
  .log-dim { color: rgba(148,163,184,0.4); }
  .log-info { color: #60a5fa; }
  .log-warn { color: var(--gold); }
